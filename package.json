{
  "name": "better-auth-offline",
  "version": "0.1.0",
  "description": "Offline-first plugin for better-auth. Transparently caches auth API responses for offline use.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/indexeddb.d.ts",
      "import": "./dist/adapters/indexeddb.js",
      "require": "./dist/adapters/indexeddb.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run tsup",
    "dev": "bun run tsup --watch",
    "test": "bun run vitest run",
    "test:watch": "bun run vitest",
    "typecheck": "bun run tsc --noEmit"
  },
  "peerDependencies": {
    "better-auth": ">=1.0.0"
  },
  "dependencies": {
    "nanostores": "^0.11.0"
  },
  "devDependencies": {
    "@better-fetch/fetch": "^1.1.0",
    "better-auth": "^1.2.0",
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "better-auth",
    "offline",
    "pwa",
    "cache",
    "offline-first"
  ],
  "license": "MIT"
}
